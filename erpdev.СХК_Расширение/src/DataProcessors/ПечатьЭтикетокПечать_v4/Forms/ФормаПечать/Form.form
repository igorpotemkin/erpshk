    <edit>
      <common>true</common>
    </edit>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	СправочникНоменклатура.Ссылка КАК Ссылка,
	СправочникНоменклатура.Код КАК Код,
	СправочникНоменклатура.Наименование КАК Наименование,
	СправочникНоменклатура.Артикул КАК Артикул
ИЗ
	Справочник.Номенклатура КАК СправочникНоменклатура
ГДЕ
	СправочникНоменклатура.ПометкаУдаления = &amp;ПометкаУдаления
	И СправочникНоменклатура.ЭтоГруппа = ЛОЖЬ
	И ВЫБОР
			КОГДА &amp;Ссылка = ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
				ТОГДА ИСТИНА
			ИНАЧЕ СправочникНоменклатура.Ссылка = &amp;Ссылка
		КОНЕЦ
	И СправочникНоменклатура.Родитель В ИЕРАРХИИ (&amp;Родитель)</queryText>

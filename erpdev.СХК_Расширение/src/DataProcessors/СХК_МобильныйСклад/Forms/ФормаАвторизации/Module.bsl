&НаКлиенте
Процедура АктивироватьПоиск() 
	ОчиститьЯчейкаСервер(); 
	Элементы.ШКпользователя.ОбновитьТекстРедактирования();
	Элементы.ШКпользователя.Видимость = Ложь;
	Элементы.ШКпользователя.Видимость = Истина;
	ЭтаФорма.ТекущийЭлемент = Элементы.ШКпользователя; 
	# Если МобильныйКлиент Тогда
		НачатьРедактированиеЭлемента();
	#КонецЕсли
	
КонецПроцедуры 

&НаСервере
Процедура ОчиститьЯчейкаСервер()
	ШКпользователя = "";
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ЭтаФорма.ТекущийЭлемент = ЭтаФорма.Элементы.ШКпользователя;
КонецПроцедуры

&НаСервере
Процедура ОчиститьСотрудника()
	Объект.Сотрудник = Справочники.Пользователи.ПустаяСсылка();
КонецПроцедуры




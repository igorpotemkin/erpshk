&НаСервере
Функция ПереместитьНаСервере()
	Перем Результат;
	Результат = Новый Структура("Успех, ТекстОшибки", Ложь, "");

	Если ЭтаФорма.Количество <= 0 Тогда
		Результат.ТекстОшибки = "Заполните количество";
		Возврат Результат;
	КонецЕсли;

	Если ЭтаФорма.ЯчейкаОтправитель = Справочники.СХК_СкладЯчейки.ПустаяСсылка() Или ЭтаФорма.ЯчейкаПолучатель
		= Справочники.СХК_СкладЯчейки.ПустаяСсылка() Тогда
		Результат.ТекстОшибки = "Отсканируйте ячейки еще раз!!!";
		Возврат Результат;
	КонецЕсли;

	ТекДок = НайтиИлиСоздатьДокументПеремещения();
	//На время инвентов
	//Если ЭтаФорма.ЯчейкаОтправитель.ШтрихКод <> "0000003720000" И ЭтаФорма.Количество * ЭтаФорма.УпаковкаУп.Числитель > СХК_ТСДСклад.ОстатокЯчейкаНоменклатура(ЭтаФорма.ЯчейкаОтправитель, ЭтаФорма.Номенклатура,
	Если ЭтаФорма.Количество * ЭтаФорма.УпаковкаУп.Числитель > СХК_ТСДСклад.ОстатокЯчейкаНоменклатура(ЭтаФорма.ЯчейкаОтправитель, ЭтаФорма.Номенклатура,
		ЭтаФорма.Серия.Наименование, ТекДок.Дата) Тогда
		Результат.ТекстОшибки = "Не достаточно товара в ячейка!!!";
		Возврат Результат;
	КонецЕсли;

	НоваяСтрока = ТекДок.ТЧТовары.Добавить();
	НоваяСтрока.Номенклатура = ЭтаФорма.Номенклатура;
	НоваяСтрока.Серия = ЭтаФорма.Серия;
	НоваяСтрока.ТекЯчейка = ЭтаФорма.ЯчейкаОтправитель;
	НоваяСтрока.НЯчейка = ЭтаФорма.ЯчейкаПолучатель;
	НоваяСтрока.Количество = ЭтаФорма.Количество * ЭтаФорма.УпаковкаУп.Числитель;
	НоваяСтрока.Время = ТекущаяДата();
	НоваяСтрока.Пользователь = ЭтаФорма.Сотрудник;
	Попытка
		ТекДок.Записать(РежимЗаписиДокумента.Проведение);
		Результат.Успех = Истина;
	Исключение
		Результат.ТекстОшибки = "Ошибка перемещения: " + ОписаниеОшибки();
	КонецПопытки;

	Возврат Результат;
КонецФункции

&НаСервере
Функция НайтиИлиСоздатьДокументПеремещения()
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	СХК_Перемещение.Ссылка КАК Ссылка
	               |ИЗ
	               |	Документ.СХК_Перемещение КАК СХК_Перемещение
	               |ГДЕ
	               |	СХК_Перемещение.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
	               |	И СХК_Перемещение.ПометкаУдаления = ЛОЖЬ
	               |	И СХК_Перемещение.Проведен = ИСТИНА
	               |	И СХК_Перемещение.Автор = &Автор"; 
	Запрос.УстановитьПараметр("ДатаНачала", НачалоДня(ТекущаяДатаСеанса()));
	Запрос.УстановитьПараметр("ДатаОкончания", КонецДня(ТекущаяДатаСеанса())); 
	Запрос.УстановитьПараметр("Автор", ЭтаФорма.Сотрудник.Ссылка); 

	Рез = Запрос.Выполнить().Выбрать();
	
	Если Рез.Следующий() Тогда
		Возврат Рез.Ссылка.ПолучитьОбъект();
	Иначе
		ТекДок = Документы.СХК_Перемещение.СоздатьДокумент();
		ТекДок.Дата = ТекущаяДатаСеанса();
		ТекДок.Автор = ЭтаФорма.Сотрудник;
		Возврат ТекДок;
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Процедура Переместить(Команда)
	
	Если НЕ ЗначениеЗаполнено(ЭтаФорма.Сотрудник) Тогда
		Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияПредупреждениеПереместить", ЭтотОбъект);
		ПоказатьПредупреждение(Оповещение, "Не выбран сотрудник!", 5, "Ошибка перемещения");
		Возврат;
	КонецЕсли;
		
	Если ПроверитьВместимость() Then	
		РезультатСервера = ПереместитьНаСервере();
		
		Если НЕ РезультатСервера.Успех Тогда 
			Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияПредупреждениеПереместить", ЭтотОбъект);
			ПоказатьПредупреждение(Оповещение, РезультатСервера.ТекстОшибки, 5, "Ошибка перемещения");
		Иначе	
			ЭтаФорма.Закрыть();
		КонецЕсли;
	Иначе
		Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияПредупреждениеПереместить", ЭтотОбъект);
		ПоказатьПредупреждение(Оповещение, "Нет места в ячейке", 5, "Ошибка перемещения");
	КонецЕсли; 

КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияПредупреждениеПереместить(Параметры) Экспорт  

КонецПроцедуры  


&НаСервере
Функция ПроверитьВместимость() 
	Если ЭтаФорма.ЯчейкаПолучатель.ШтрихКод = "0000003720000" Тогда
		Возврат Истина;
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	СХК_ТоварыНаСкладеОстатки.ВНаличииОстаток КАК ВНаличииОстаток,
	|	ВЫБОР
	|		КОГДА СХК_ТоварыНаСкладеОстатки.Ячейка.ВМестимость = ЗНАЧЕНИЕ(Перечисление.СХК_ВМестимость.Палет)
	|			ТОГДА 20000 - СХК_ТоварыНаСкладеОстатки.ВНаличииОстаток
	|		ИНАЧЕ 300000 - СХК_ТоварыНаСкладеОстатки.ВНаличииОстаток
	|	КОНЕЦ КАК Лимит
	|ИЗ
	|	РегистрНакопления.СХК_ТоварыНаСкладе.Остатки КАК СХК_ТоварыНаСкладеОстатки
	|ГДЕ
	|	СХК_ТоварыНаСкладеОстатки.Ячейка = &Ячейка";   
	Запрос.УстановитьПараметр("Ячейка",ЭтаФорма.ЯчейкаПолучатель); 
	Результат = Запрос.Выполнить().Выбрать();
	Если Результат.Следующий() Тогда
		Если Результат.Лимит >= ЭтаФорма.Количество*ЭтаФорма.УпаковкаУп.Числитель Тогда
			Возврат Истина;
		Иначе
			Возврат Ложь;
		КонецЕсли;
	Иначе
		Возврат Истина;
	КонецЕсли;
	
КонецФункции






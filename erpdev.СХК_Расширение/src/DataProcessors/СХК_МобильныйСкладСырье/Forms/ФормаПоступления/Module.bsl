&НаСервере
Функция ПолучитьПриходныйОрдер(Заказ)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ПриходныйОрдерНаТовары.Ссылка КАК Ссылка
	               |ИЗ
	               |	Документ.ПриходныйОрдерНаТовары КАК ПриходныйОрдерНаТовары
	               |ГДЕ
	               |	ПриходныйОрдерНаТовары.ПометкаУдаления = ЛОЖЬ
	               //|	И ПриходныйОрдерНаТовары.Проведен = ЛОЖЬ
	               |	И ТИПЗНАЧЕНИЯ(ПриходныйОрдерНаТовары.Распоряжение) = ТИП(Документ.ЗаказПоставщику)
	               |	И ПриходныйОрдерНаТовары.Распоряжение = &Ссылка
	               |	И ПриходныйОрдерНаТовары.НомерВходящегоДокумента = &НомерВходящегоДокумента";
	Запрос.УстановитьПараметр("Ссылка",Заказ.Ссылка );
	Запрос.УстановитьПараметр("НомерВходящегоДокумента",ЭтотОбъект.НомерУПД );
	Результат = Запрос.Выполнить().Выбрать();
	Если Результат.Следующий() Тогда
		Возврат Результат.Ссылка;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции



&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если Не ПроверитьУПД() Тогда
		ОткрытьФормуУПД(); 
	Иначе
		ПроверитьСоздатьДокументПО();
		ОбработатьТабЧасть("");
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
Функция ПроверитьУПД()

	Если ЗначениеЗаполнено(ЭтаФорма.НомерУПД) И ЗначениеЗаполнено(ЭтаФорма.ДатаУПД) Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции



&НаКлиенте
Процедура ОткрытьФормуУПД()
	
	СтандартнаяОбработка = Ложь;
	ПараметрыФормыОстатки = Новый Структура;
	ПараметрыФормыОстатки.Вставить("ЗаказПоставщику",ДокументЗаказПоставщику);
	АдресПередаваемыхПараметров = ПоместитьВоВременноеХранилище(ПараметрыФормыОстатки,Новый УникальныйИдентификатор);
	_Параметры = новый Структура("Адрес", АдресПередаваемыхПараметров);
	//@skip-check notify-description-to-server-procedure
	ОписаниеОповещения = Новый ОписаниеОповещения("ОбработатьЗакрытиеФормыФормаУПД", ЭтаФорма);
	ОткрытьФорму("Обработка.СХК_МобильныйСкладСырье.Форма.ФормаУПД", _Параметры,ЭтаФорма, , , , ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьЗакрытиеФормыФормаУПД(Значение, ДопПараметры) Экспорт

	Если ЗначениеЗаполнено(Значение) Тогда  
		Если Значение.НомерУПД <> 0 Тогда
			ЭтотОбъект.ДатаУПД = Значение.ДатаУПД;  
			ЭтотОбъект.НомерУПД = Значение.НомерУПД; 
			ПроверитьСоздатьДокументПО();
			ОбработатьТабЧасть("");
		Иначе
			ОткрытьФормуВопроса();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуВопроса()
	Ответ = Вопрос("Ввести номер УПД?",//"Ордер собран",//"Разместить ордер ?",
	РежимДиалогаВопрос.ДаНетОтмена,
	0, // таймаут в секундах
	КодВозвратаДиалога.Да, // (необ.) кнопка по умолчанию
	"Ввести номер УПД?" // (необ.) заголовок
	//"По данному ордеру все собрано !!!"
	);
	
	Если Ответ = КодВозвратаДиалога.Да Тогда
		ОткрытьФормуУПД();
	Иначе
		ЭтаФорма.Закрыть();
	КонецЕсли;
	
КонецПроцедуры




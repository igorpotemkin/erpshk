&НаСервере
Процедура ИзменитьТабЧасть(Структура)
	
	Если ЗначениеЗаполнено(Структура) Тогда  
		
			Отбор = Новый Структура;
			Отбор.Вставить("Номенклатура",Структура.Номенклатура);
			Отбор.Вставить("Принято",Истина);
			Отбор.Вставить("СерияНоменклатуры",Структура.СерииНоменклатуры);
			Строки = Товары.НайтиСтроки(Отбор); 
			Если Строки.Количество()>=1 Тогда
				СтрокаИзм = Строки[0];
			КонецЕсли;
				
			ОтборН = Новый Структура;
			ОтборН.Вставить("Номенклатура",Структура.Номенклатура);
			ОтборН.Вставить("Принято",Ложь);
			СтрокиОтбор = Товары.НайтиСтроки(ОтборН);

			Если СтрокиОтбор.Количество()>=1 Тогда
				СтрокиРод = СтрокиОтбор[0];
			КонецЕсли;
			
			Если Структура.КоличествоУпаковокПринято = 0 Тогда
				СтрокиРод.КоличествоПринято = СтрокиРод.КоличествоПринято - СтрокаИзм.КоличествоПринято;
				Товары.Удалить(СтрокаИзм);
			ИначеЕсли Структура.КоличествоУпаковокПринято > 0 Тогда   
				СтрокиРод.КоличествоПринято = СтрокиРод.КоличествоПринято - СтрокаИзм.КоличествоПринято+Структура.КоличествоУпаковокПринято;
				СтрокаИзм.КоличествоПринято	= Структура.КоличествоУпаковокПринято;
				СтрокаИзм.НомерСтрокиДокумента	= Структура.НомерСтрокиДокумента;
			КонецЕсли;
 
		Товары.Сортировать("Принято Возр");
	КонецЕсли;
	
КонецПроцедуры





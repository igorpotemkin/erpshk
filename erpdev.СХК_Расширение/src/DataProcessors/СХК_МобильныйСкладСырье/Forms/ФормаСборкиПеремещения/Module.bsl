&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	СтруктураПараметров = ПолучитьИзВременногоХранилища(Параметры.Адрес);
	Если СтруктураПараметров.ДокументЗаказПеремещения <> "" Тогда
		ЭтотОбъект.ДокументЗаказПеремещения = СтруктураПараметров.ДокументЗаказПеремещения;
		ЗаполнитьФорму(СтруктураПараметров.ДокументЗаказПеремещения,СтруктураПараметров.СтрокаДокументЗаказПеремещения);
	Иначе
		Отказ = Истина;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьФорму(ДокЗаказа,СтрокаЗаказа)
	
	ЭтотОбъект.Номенклатура = СтрокаЗаказа.Номенклатура; 
	ЭтотОбъект.СкладОтправитель = ДокЗаказа.СкладОтправитель;
	Вложение = ПроверитьВложение(СтрокаЗаказа.Номенклатура);
	ЭтотОбъект.КоличествоВложений = ?(Вложение>0,Вложение,0);

	Если Вложение >=1 Тогда
		ЭтаФОрма.Элементы.ВыборУпаковки.Видимость = Истина;	
	Иначе
		ЭтотОбъект.Упаковка = СтрокаЗаказа.Номенклатура.ЕдиницаИзмерения;
	КонецЕсли;
	
	Если СтрокаЗаказа.Номенклатура.ВидНоменклатуры.ИспользоватьСерии = Ложь Тогда
		Элементы.ВыбратьСерию.Доступность = Ложь;
		ЭтотОбъект.ПараметрыУказанияСерий = Ложь;
	Иначе 
		//Элементы.КоличествоУпаковокСобрано.Доступность = Ложь;
		Отбор = Новый Структура;
		Отбор.Вставить("Склад",ДокЗаказа.СкладОтправитель);
		Отбор.Вставить("ПолитикаУчетаСерий",Справочники.ПолитикиУчетаСерий.НайтиПоНаименованию("Учет себестоимости по сериям"));
		Строки = СтрокаЗаказа.Номенклатура.ВидНоменклатуры.ПолитикиУчетаСерий.НайтиСтроки(Отбор);
		
		Если Строки.Количество()>=1 Тогда
			ЭтотОбъект.ПараметрыУказанияСерий = Истина; 
			ЭтотОбъект.ИспользоватьСерии = Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	
	ЭтотОбъект.СерииНоменклатуры = СтрокаЗаказа.СерииНоменклатуры; 
	Если Не ЭтотОбъект.СерииНоменклатуры.Пустая() Тогда
		ЭтотОбъект.Упаковка = ЭтотОбъект.СерииНоменклатуры.СХК_Упаковка;
	КонецЕсли;
	
	ЭтотОбъект.КоличествоУпаковок = СтрокаЗаказа.КоличествоУпаковок;
	ЭтаФорма.Элементы.ЕдДок.Заголовок = ЭтотОбъект.Номенклатура.ЕдиницаИзмерения; 
	ЭтотОбъект.КоличествоУпаковокСобрано = СтрокаЗаказа.КоличествоУпаковокСобрано;
	
	ДокРО = ПолучитьРасходныйОрдер(ДокЗаказа);
	Если ДокРО = Ложь Тогда
		НовыйДокРО = Документы.РасходныйОрдерНаТовары.СоздатьДокумент();
		НовыйДокРО.Дата = ТекущаяДата();  
		НовыйДокРО.ДатаОтгрузки = ТекущаяДата();  
		НовыйДокРО.Ответственный = Пользователи.АвторизованныйПользователь();
		НовыйДокРО.Получатель = Перечисления.СкладскиеОперации.ПриемкаОтПоставщика; 
		НовыйДокРО.Получатель = ДокЗаказа.СкладПолучатель;
		НовыйДокРО.Склад = ДокЗаказа.СкладОтправитель;
		НовыйДокРО.СкладскаяОперация = Перечисления.СкладскиеОперации.ОтгрузкаПоПеремещению;
		НовыйДокРО.Статус = Перечисления.СтатусыРасходныхОрдеров.КОтгрузке;
		НовыйДокРО.Приоритет = Справочники.Приоритеты.НайтиПоНаименованию("Средний");
		НовыйДокРО.Записать(РежимЗаписиДокумента.Запись); 
		ДокументРО = НовыйДокРО.Ссылка;
	Иначе
		ДокументРО = ДокРО.Ссылка;
		Если СтрокаЗаказа.КоличествоУпаковокСобрано > 0 Тогда
			Элементы.Добавить.Видимость = Ложь;
			Элементы.Изменить.Видимость = Истина;
			Если СтрокаЗаказа.СерииНоменклатуры = Справочники.СерииНоменклатуры.ПустаяСсылка() Тогда
				Элементы.СоздатьСерииНоменклатуры.Доступность = Ложь; 
			КонецЕсли;  
		Иначе 
			Собрано = 0;
			Отбор = Новый Структура;
			Отбор.Вставить("Номенклатура",СтрокаЗаказа.Номенклатура);
			//Отбор.Вставить("Серия",СтрокаЗаказа.СерииНоменклатуры); 
			Строки = ДокументРО.ОтгружаемыеТовары.НайтиСтроки(Отбор);
			Если Строки.Количество()>=1 Тогда
				Для сч=0 по Строки.Количество()-1 Цикл
					Собрано = Собрано + Строки[сч].КоличествоУпаковок;
				КонецЦикла;
				Элементы.ДекорацияОстаток.Заголовок = "Осталось собрать: " +Строка(?(СтрокаЗаказа.КоличествоУпаковок - Собрано>0,СтрокаЗаказа.КоличествоУпаковок - Собрано,0));// - Собрано);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;	 

КонецПроцедуры

&НаСервере
Функция ПолучитьРасходныйОрдер(Заказ)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 1
	|	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.РасходныйОрдерНаТовары.ТоварыПоРаспоряжениям КАК РасходныйОрдерНаТоварыТоварыПоРаспоряжениям
	|ГДЕ
	|	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Распоряжение = &Распоряжение
	|	И РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка.Проведен = ИСТИНА
	|	И ТИПЗНАЧЕНИЯ(РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Распоряжение) = ТИП(Документ.ЗаказНаПеремещение)
	|	И РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка.ПометкаУдаления = ЛОЖЬ";
	Запрос.УстановитьПараметр("Распоряжение",Заказ.Ссылка );
	Результат = Запрос.Выполнить().Выбрать();
	Если Результат.Следующий() Тогда
		Возврат Результат.Ссылка;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции


&НаКлиенте
Процедура ОткрытьФормуВыбораСерии()
	СтандартнаяОбработка = Ложь;
	ПараметрыФормыОстатки = Новый Структура;
	ПараметрыФормыОстатки.Вставить("Склад",ЭтотОбъект.СкладОтправитель);
	ПараметрыФормыОстатки.Вставить("Номенклатура",ЭтотОбъект.Номенклатура);
	АдресПередаваемыхПараметров = ПоместитьВоВременноеХранилище(ПараметрыФормыОстатки,Новый УникальныйИдентификатор);
	_Параметры = новый Структура("Адрес", АдресПередаваемыхПараметров);
	//@skip-check notify-description-to-server-procedure
	ОписаниеОповещения = Новый ОписаниеОповещения("ОбработатьЗакрытиеВыбратьСерию", ЭтаФорма);
	ОткрытьФорму("Обработка.СХК_МобильныйСкладСырье.Форма.ФормаВыбораСерии", _Параметры,ЭтаФорма, , , , ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры


&НаКлиенте
Процедура ВыборСерии(Команда)
	ОткрытьФормуВыбораСерии();
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьЗакрытиеВыбратьСерию(Значение, ДопПараметры) Экспорт
	Если ЗначениеЗаполнено(Значение) Тогда                  

		ЭтотОбъект.СерииНоменклатуры = Значение.СерииНоменклатуры;  
		ЭтотОбъект.ДоступныйОстаток = Значение.ДоступныйОстаток; 
		ЭтотОбъект.Упаковка = Значение.Упаковка; 
		ед = ЕдиницаИзмеренияНоменклатуры();
		
		Если ЗначениеЗаполнено(Значение.Упаковка) Тогда
			Если Значение.Упаковка <> ед.ЕдиницаИзмерения Тогда
				ЭтотОбъект.ДоступныйОстатокЕД = Строка(Значение.ДоступныйОстаток/ед.Числитель) + " упак";// + " " + Строка(ед.ЕдиницаИзмерения);
			КонецЕсли;
		КонецЕсли;
		
		ОчиститьКоличествоУпаковокПринято();
		АктивироватьКоличествоУпаковокПринято();
		ЭтаФорма.Элементы.Декорация1.Заголовок = "";
		ПроверитьСерииДокумент();
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ПроверитьСерииДокумент() 
		Док = ЭтотОбъект.ДокументРО.ПолучитьОбъект();
		
		ТабРасп = Док.ТоварыПоРаспоряжениям.Выгрузить();
		Отбор = Новый Структура;
		Отбор.Вставить("Номенклатура", ЭтотОбъект.Номенклатура);
		Отбор.Вставить("Серия", ЭтотОбъект.СерииНоменклатуры.Ссылка);
		
		Строки = ТабРасп.НайтиСтроки(Отбор);
		Если Строки.Количество()>=1 Тогда  
			Элементы.Добавить.Видимость = Ложь;
			Элементы.Изменить.Видимость = Истина; 
			Элементы.ДекорацияСобрали.Заголовок = "Собрано: " +Строка(Строки[0].Количество);// - Собрано);
		КонецЕсли;
КонецПроцедуры


 &НаСервере
 Функция ЕдиницаИзмеренияНоменклатуры() 
	 СЗ = Новый Структура;
	 СЗ.Вставить("ЕдиницаИзмерения",ЭтотОбъект.Номенклатура.ЕдиницаИзмерения); 
	 Если ЗначениеЗаполнено(ЭтотОбъект.СерииНоменклатуры.СХК_Упаковка) Тогда
	 	СЗ.Вставить("Числитель",ЭтотОбъект.СерииНоменклатуры.СХК_Упаковка.Числитель); 
	Иначе
	 	СЗ.Вставить("Числитель",ЭтотОбъект.Номенклатура.ЕдиницаИзмерения.Числитель); 
	КонецЕсли;
	
	 Возврат СЗ;
 КонецФункции
 


			Иначе  
				СтрокиПеремещения[0].КоличествоУпаковок = ЭтотОбъект.КоличествоУпаковокСобрано * ЭтотОбъект.Упаковка.Числитель;;	
				СтрокиПеремещения[0].Количество = ЭтотОбъект.КоличествоУпаковокСобрано * ЭтотОбъект.Упаковка.Числитель;;
				Если СтрокиИ.Количество() = 1 Тогда 
					СтрокиИ[0].КоличествоУпаковок = (СтрокиИ[0].КоличествоУпаковок + Собрано) -ЭтотОбъект.КоличествоУпаковокСобрано * ЭтотОбъект.Упаковка.Числитель;;	
					СтрокиИ[0].Количество = (СтрокиИ[0].Количество + Собрано) - ЭтотОбъект.КоличествоУпаковокСобрано * ЭтотОбъект.Упаковка.Числитель;;
				конецЕсли;	
				
			КонецЕсли;
					Попытка
						докЗаказ.Записать(РежимЗаписиДокумента.Проведение);
					Исключение
						Ош = "При проведении возникла ошибка";
						Возврат  Ош;
					КонецПопытки;						

			
	КонецЕсли;		

	Возврат  Ош;
	
КонецФункции

&НаСервере
Функция ПроверитьУпаковку()
	Ош = Истина;
	ЭтаФорма.Элементы.Декорация1.Заголовок = "";
	Если ЭтаФорма.Упаковка = Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка() Тогда 
		ЭтаФорма.Элементы.Декорация1.Заголовок = "Заполните упаковку";
		КоличествоУпаковокСобрано = 0;
		Ош = Ложь;
	КонецЕсли;     
	Возврат Ош;
КонецФункции

	
&НаКлиенте
Процедура Плюс(Команда)  
	Если ПроверитьУпаковку() Тогда
		КоличествоУпаковокСобрано = КоличествоУпаковокСобрано + 1; 
		КоличествоУпаковокСобраноПриИзмененииНаСервере();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Минус(Команда)
	Если ПроверитьУпаковку() Тогда
		КоличествоУпаковокСобрано = КоличествоУпаковокСобрано - 1; 
		КоличествоУпаковокСобраноПриИзмененииНаСервере();
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура КоличествоУпаковокСобраноПриИзмененииНаСервере()
	Элементы.ДекорацияСобрали.Заголовок = "Собрано: " +Строка(ЭтаФорма.КоличествоУпаковокСобрано * ЭтаФорма.Упаковка.Числитель);// - Собрано);
КонецПроцедуры

&НаКлиенте
Процедура КоличествоУпаковокСобраноПриИзменении(Элемент) 
	Если ПроверитьУпаковку() Тогда
		КоличествоУпаковокСобраноПриИзмененииНаСервере(); 
	КонецЕсли;
КонецПроцедуры



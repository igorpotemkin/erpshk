&НаКлиенте
Процедура Добавить(Команда)
	Ош = ДобавитьНаСервере(Ложь);
	Если Ош = Ложь Тогда
		ЭтаФорма.Закрыть();
	Иначе
		Если Ош = 1 Тогда
			ВывестиВопросКоличествоПревышает();
		Иначе
			Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияПредупреждениеСохранения", ЭтотОбъект);	
			ПоказатьПредупреждение(Оповещение,Строка(Ош),5,"Внимание!!!");
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры   

&НаКлиенте 
Процедура ВывестиВопросКоличествоПревышает()
	
	//@skip-check undefined-function
	Ответ = Вопрос("Количество превышает по документу, ПЕРЕМЕСТИТЬ?",//"Ордер собран",//"Разместить ордер ?",
	РежимДиалогаВопрос.ДаНет,
	0, // таймаут в секундах
	КодВозвратаДиалога.Да, // (необ.) кнопка по умолчанию
	"Вопрос" // (необ.) заголовок
	//"По данному ордеру все собрано !!!"
	);
	
	Если Ответ = КодВозвратаДиалога.Да Тогда
 		Ош = ДобавитьНаСервере(Истина);
		Если Ош = Ложь Тогда
			ЭтаФорма.Закрыть();
		Иначе
			Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияПредупреждениеСохранения", ЭтотОбъект);	
			ПоказатьПредупреждение(Оповещение,Строка(Ош),5,"Внимание!!!");
		КонецЕсли;
	Иначе
		АктивироватьКоличествоУпаковокПринято()	;
	КонецЕсли;

КонецПроцедуры



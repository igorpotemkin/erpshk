&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)
	СтуктураВозврат = Новый Структура;
	СтуктураВозврат.Вставить("СерииНоменклатуры",ЭтаФорма.СерииНоменклатуры);
	СтуктураВозврат.Вставить("Номенклатура",ЭтаФорма.Номенклатура);
	СтуктураВозврат.Вставить("Упаковка",ЭтаФорма.Упаковка);
	СтуктураВозврат.Вставить("КоличествоУпаковокПринято",ИтогКоличестваПоФорме());
	СтуктураВозврат.Вставить("НомерСтрокиДокумента",ЭтаФорма.НомерСтрокиДокумента);
	ОповеститьОВыборе(СтуктураВозврат); 
КонецПроцедуры

&НаСервере
Функция ИтогКоличестваПоФорме()
	Возврат  ЭтотОбъект.КоличествоУпаковокПринято*ЭтотОбъект.Упаковка.Числитель + ЭтотОбъект.ДополнительноеКоличество; 
	
КонецФункции

&НаСервере
Процедура УпаковкаПриИзмененииНаСервере()
	ЭтаФорма.СерииНоменклатуры = Справочники.СерииНоменклатуры.ПустаяСсылка(); 
	ЭтаФорма.КоличествоУпаковокПринято = 0;
КонецПроцедуры

&НаКлиенте
Процедура УпаковкаПриИзменении(Элемент)
	УпаковкаПриИзмененииНаСервере();
КонецПроцедуры


&НаСервере
Функция РасчитатьКоличествоУпаковок()
	СтрокаДокумента = ДокументПО.Товары[ЭтотОбъект.НомерСтрокиДокумента];
	
	СтруктураСтрока = Новый Структура("КоличествоУпаковок,Серия");
	ЗаполнитьЗначенияСвойств(СтруктураСтрока, СтрокаДокумента);	 
	
	КоличествоУпаковок = СтрокаДокумента.КоличествоУпаковок;
	Если Не СтрокаДокумента.Серия.Пустая() Тогда
		Если ЗначениеЗаполнено(СтрокаДокумента.Серия.СХК_Упаковка) Тогда
			КоличествоУпаковок = СтрокаДокумента.КоличествоУпаковок / СтрокаДокумента.Серия.СХК_Упаковка.Числитель;
		КонецЕсли;
	КонецЕсли;  
	
	СтруктураСтрока.Вставить("КоличествоУпаковок",КоличествоУпаковок);

	Возврат СтруктураСтрока;
КонецФункции


&НаКлиенте
Процедура ВыборУпаковки(Команда)
	ОткрытьФормуВыбораУпаковки();
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуВыбораУпаковки()
	СтандартнаяОбработка = Ложь;
	ПараметрыФормыОстатки = Новый Структура;
	ПараметрыФормыОстатки.Вставить("Номенклатура",ЭтотОбъект.Номенклатура);
	АдресПередаваемыхПараметров = ПоместитьВоВременноеХранилище(ПараметрыФормыОстатки,Новый УникальныйИдентификатор);
	_Параметры = новый Структура("Адрес", АдресПередаваемыхПараметров);
	//@skip-check notify-description-to-server-procedure
	ОписаниеОповещения = Новый ОписаниеОповещения("ОбработатьЗакрытиеФормыВыборУпаковки", ЭтаФорма);
	ОткрытьФорму("Обработка.СХК_МобильныйСкладСырье.Форма.ФормаУпаковки", _Параметры,ЭтаФорма, , , , ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс );
	
КонецПроцедуры


&НаКлиенте
Процедура ОбработатьЗакрытиеФормыВыборУпаковки(Значение, ДопПараметры) Экспорт
	Если ЗначениеЗаполнено(Значение) Тогда
		ЭтаФорма.Элементы.Декорация1.Заголовок = "";
		Если Не Значение.Упаковка.Пустая() Тогда
			ЭтотОбъект.Упаковка = Значение.Упаковка; 
			//Элементы.КоличествоУпаковокПринято.Доступность = Истина;
			//ПересчитатьУпаковки();
		Иначе
			ЭтотОбъект.Упаковка = ЕдиницаИзмеренияНоменклатуры();
			//Элементы.КоличествоУпаковокПринято.Доступность = Ложь;
			ОчиститьКоличествоУпаковок();
		КонецЕсли; 
		ОчиститьСерию();
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ПересчитатьУпаковки()
	ЭтаФорма.КоличествоУпаковокПринято = КоличествоУпаковокПринято/Упаковка.Числитель;			
КонецПроцедуры


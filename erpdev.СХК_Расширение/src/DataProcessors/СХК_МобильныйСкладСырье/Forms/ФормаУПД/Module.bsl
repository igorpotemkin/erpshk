
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	СтруктураПараметров = ПолучитьИзВременногоХранилища(Параметры.Адрес);

	Если ЗначениеЗаполнено(СтруктураПараметров.ЗаказПоставщику) Тогда
		ДокументЗаказПоставщику = СтруктураПараметров.ЗаказПоставщику;
		ДатаУПД =  ДокументЗаказПоставщику.Ссылка.ЖелаемаяДатаПоступления;
	Иначе
		Сообщить("Не удалось создать документ отгрузки");	
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ЭтаФорма.Элементы.НомерУПД.РедактированиеТекста = Истина;
	АктивироватьПолеНомерУПД();

КонецПроцедуры

&НаКлиенте
Процедура АктивироватьПолеНомерУПД() 
	ОчиститьПолеНомерУПД(); 
	Элементы.НомерУПД.ОбновитьТекстРедактирования();
	Элементы.НомерУПД.Видимость = Ложь;
	Элементы.НомерУПД.Видимость = Истина;
	ЭтаФорма.ТекущийЭлемент = Элементы.НомерУПД; 
	# Если МобильныйКлиент Тогда
		НачатьРедактированиеЭлемента();
	#КонецЕсли
	
КонецПроцедуры 

&НаСервере
Процедура ОчиститьПолеНомерУПД()
	НомерУПД = "";
КонецПроцедуры

&НаКлиенте
Процедура Поступление(Команда)
	Ош = ПроверитьПоля();
	Если Ош = Ложь Тогда   
		ЭтаФорма.Закрыть();
	Иначе
		Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияПредупреждение", ЭтотОбъект);	
		ПоказатьПредупреждение(Оповещение,Строка(Ош),5,"Внимание!!!");
		
	КонецЕсли;
	
КонецПроцедуры

